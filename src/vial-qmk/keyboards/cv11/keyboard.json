            ["B13", "A1", "B11", "B1", "A4", "B10", "B2", "A5", "B0", "A7", "A6"]
        ]
    },
    "encoder": {
        "rotary": [
            {"pin_a": "B14", "pin_b": "B15", "resolution": 4}
        ]
    },
    "layouts": {
