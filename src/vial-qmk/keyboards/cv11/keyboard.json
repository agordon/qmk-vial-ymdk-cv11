{
    "manufacturer": "MTKB",
    "keyboard_name": "CV11-gordon",
    "maintainer": "qmk",
    "development_board": "bluepill",
    "bootloader": "custom",
    "processor": "STM32F103",
    "url": "",
    "usb": {
        "device_version": "0.0.2",
