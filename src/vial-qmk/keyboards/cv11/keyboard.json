                {"matrix": [0, 3],  "x": 4.25, "y": 0},
                {"matrix": [0, 4],  "x": 2,    "y": 1},
                {"matrix": [0, 5],  "x": 3.25, "y": 1},
                {"matrix": [0, 6],  "x": 4.25, "y": 1},
                {"matrix": [0, 7],  "x": 2,    "y": 2},
                {"matrix": [0, 8],  "x": 3.25, "y": 2},
                {"matrix": [0, 9],  "x": 4.25, "y": 2},
                {"matrix": [0, 10], "x": 2,    "y": 3}
            ]
        }
